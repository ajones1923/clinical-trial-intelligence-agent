# =============================================================================
# Clinical Trial Intelligence Agent - Environment Configuration
# Copy this file to .env and set your values
# =============================================================================

# -- Anthropic API Key (required for LLM features) --
ANTHROPIC_API_KEY=sk-ant-your-key-here

# -- Milvus Vector Database --
TRIAL_MILVUS_HOST=localhost
TRIAL_MILVUS_PORT=19530

# -- Service Ports --
TRIAL_API_PORT=8538
TRIAL_STREAMLIT_PORT=8128

# -- Embeddings --
TRIAL_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# -- LLM --
TRIAL_LLM_MODEL=claude-sonnet-4-6

# -- RAG Search --
TRIAL_TOP_K_PER_COLLECTION=5
TRIAL_SCORE_THRESHOLD=0.4

# -- Authentication (empty = no auth required) --
TRIAL_API_KEY=

# -- CORS --
TRIAL_CORS_ORIGINS=http://localhost:8080,http://localhost:8538,http://localhost:8128

# -- Scheduled Ingest (ClinicalTrials.gov, PubMed) --
TRIAL_INGEST_ENABLED=false
TRIAL_INGEST_SCHEDULE_HOURS=24

# -- External APIs (optional) --
TRIAL_CLINICALTRIALS_API_KEY=
TRIAL_NCBI_API_KEY=

# -- Prometheus Metrics --
TRIAL_METRICS_ENABLED=true

# -- Request Limits --
TRIAL_MAX_REQUEST_SIZE_MB=10
